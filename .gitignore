# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor — track native source projects, ignore builds and generated assets
/android/.gradle/
/android/build/
/android/app/build/
/android/local.properties
/android/captures/
/android/app/release/
/android/app/src/main/assets/capacitor.plugins.json
/android/app/src/main/assets/capacitor.config.json
/android/app/src/main/assets/public/
/ios/App/Pods/
/ios/App/Podfile.lock
/ios/App/build/
/ios/DerivedData/
/ios/App/App/public/
/ios/capacitor-cordova-ios-plugins/
.capacitor/

# Sentry Config File
.env.sentry-build-plugin

# Draft XI — raw FIFA source CSVs (large; dataset is regenerated into src/data/draft)
scripts/draft/data/raw/
social-media/store/screenshots/v2-raw/
emails/preview/

# Health-check run artifacts (scorecards, screenshots, bot-seen history)
scripts/data/health/

# Never commit env backups (they carry prod secrets)
.env.local.bak*
