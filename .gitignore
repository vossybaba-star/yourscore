# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
# Verification builds (NEXT_DIST_DIR=.next-verify) — run so a prod build can be
# checked without clobbering a running dev server's .next.
/.next-verify/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor — track native source projects, ignore builds and generated assets
/android/.gradle/
/android/build/
/android/app/build/
/android/local.properties
/android/captures/
/android/app/release/
/android/app/src/main/assets/capacitor.plugins.json
/android/app/src/main/assets/capacitor.config.json
/android/app/src/main/assets/public/
/ios/App/Pods/
/ios/App/Podfile.lock
/ios/App/build/
/ios/DerivedData/
/ios/App/App/public/
/ios/capacitor-cordova-ios-plugins/
.capacitor/

# Sentry Config File
.env.sentry-build-plugin

# Draft XI — raw FIFA source CSVs (large; dataset is regenerated into src/data/draft)
scripts/draft/data/raw/
social-media/store/screenshots/v2-raw/
emails/preview/

# Health-check run artifacts (scorecards, screenshots, bot-seen history)
scripts/data/health/

# SportMonks fact cache (quiz factory). Derived data — past seasons are immutable so it's
# fetched once and reused, but it rebuilds itself from the API on any machine. ~2MB.
scripts/data/sportmonks-cache/

# Halftime pipeline run artifacts: the veto/auto-release decision log (JSONL,
# one file per matchday), generated slates, and poller run-state. The audit log
# is the record of who approved what — it belongs on the VPS, not in git.
scripts/data/halftime/

# Never commit env backups (they carry prod secrets)
.env.local.bak*
.env*
